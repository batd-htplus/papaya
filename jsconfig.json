{
    "compilerOptions": {
        "checkJs": true,
        "strict": false,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "noEmit": true,
        "allowJs": true
    },
    "include": [
        "scripts/**/*.mjs"
    ]
}
