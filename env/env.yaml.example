# Project defaults. Copy/keep this committed; never put secrets here.
# For local-only overrides, use env/env.local.yaml (gitignored).

base_url: https://example.com   # project base URL
username: null                  # set in env/env.local.yaml if needed
password: null                  # set in env/env.local.yaml if needed
timeout_ms: 25000               # per-step timeout default
viewport: 1280x720
headless: true

# Logging:
#   minimal - no run.log; snapshot/diff only on failure (default)
#   normal  - run.log; snapshot/diff only on failure
#   verbose - run.log; snapshot/diff every step
log_level: minimal
